NEXT_PUBLIC_SITE_URL=https://your-domain.example
DATABASE_PATH=/data/app.db
# AWS Lambda Function URL for the "Ask the Agent" demo (Play page). Read at RUNTIME
# by the server (play/page.tsx), NOT inlined — must be a plain var, not NEXT_PUBLIC_*.
# Unset = offline mock mode.
AGENT_URL=
# Force offline mock agent in dev (set to "mock"). Leave blank to use the Lambda.
NEXT_PUBLIC_AGENT_MODE=
# Shared HMAC secret for the signed-request token sent to the Lambda. Read at
# RUNTIME server-side by /api/agent-token — NEVER NEXT_PUBLIC_*, never committed.
# Must hold the SAME value as the Lambda's SST secret AgentSigningSecret.
# Unset = token gate disabled on the Next side (route returns { token: null }).
AGENT_SIGNING_SECRET=
